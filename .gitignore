# Generated by Cargo
# will have compiled files and executables
debug
target

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/

# RustRover
#  JetBrains specific template is maintained in a separate JetBrains.gitignore that can
#  be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
#  and can be added to the global gitignore or merged into this file.  For a more nuclear
#  option (not recommended) you can uncomment the following to ignore the entire idea folder.
#.idea/

# Frontend (Vite + TypeScript)
frontend/node_modules/
frontend/dist/
frontend/.vite/
vscode-extension/node_modules/
vscode-extension/dist/
*.log

# VS Code extension build artifacts (generated by `npm run build` /
# `build:assets` / `build:preview`; the committed sources are
# `media/preview.css` and the shared `frontend-core/`). Plus the packaged
# VSIX and the bundled server binary.
vscode-extension/media/ar5iv.css
vscode-extension/media/ar5iv-fonts.css
vscode-extension/media/preview.js
vscode-extension/media/preview.js.map
vscode-extension/bin/
vscode-extension/*.vsix

# Vendored VS Code Web standalone build, fetched by
# `vscode-extension/scripts/fetch-vscode-web.mjs` and served at /vscode.
# Reproducible from a pinned version hash, never committed (tens of MB).
/vscode-web/

# OS
.DS_Store

# Secrets — `deploy/.env` is minted by `deploy/vultr-bootstrap.sh`
# (and the local-test rehearsal under /tmp) and contains the
# Anubis ed25519 cookie-signing key. Keep it out of the tree even
# if someone runs the bootstrap script from inside a checkout.
.env
.env.*
!.env.example
*.pem
*.key
credentials*.json
.netrc
.npmrc

# Claude Code local state
.claude/
